#!/bin/sh
# Exit on any error except when "No tests found!" in bun test output
set -e

# Run bun test and allow it to fail unless output contains "No tests found!"
BUN_TEST_OUTPUT=$(bun test 2>&1) || {
  echo "$BUN_TEST_OUTPUT" | grep -q "No tests found!" && {
    echo "$BUN_TEST_OUTPUT"
    echo "No tests found. Proceeding with commit."
  } || {
    echo "$BUN_TEST_OUTPUT"
    echo "bun test failed."
    exit 1
  }
}

# Check if there are any staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

# Run formatter
bun x ultracite fix
FORMAT_EXIT_CODE=$?

# Re-stage files that were already staged
echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done

if [ $FORMAT_EXIT_CODE -ne 0 ]; then
  echo "Ultracite found issues that could not be auto-fixed."
  exit $FORMAT_EXIT_CODE
fi

echo "✨ Files formatted by Ultracite"
